# This is an example of your .env file to use, rename file to .env to use
# Zoom OAuth 2.0 Credentials
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_ACCOUNT_ID=your_zoom_account_id

# rclone Google Drive Configuration
RCLONE_REMOTE_NAME=drive
RCLONE_BASE_PATH=Zoom/Recordings

# Optional Slack Integration
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Debug Mode (set to true to enable verbose logging and skip actual file operations)
DEBUG=false
